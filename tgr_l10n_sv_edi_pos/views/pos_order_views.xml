<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_order_form_inherit_l10n_sv_edi_pos" model="ir.ui.view">
        <field name="name">pos.order.form</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"></field>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='order_fields']" position="inside">
                <field invisible="not tgr_l10n_sv_edi_tipo_invalidacion" name="tgr_l10n_sv_edi_tipo_invalidacion"></field>
            </xpath>
            <!-- Add DTE fieles -->
      <xpath expr="//notebook/page[last()]" position="after">
        <page string="DTE" invisible="country_code!='SV'" >
          <group>
            <group>
              
              <field name="tgr_l10n_sv_edi_numero_control"></field>
              <field name="tgr_l10n_sv_edi_codigo_generacion"></field> 
              <field name="tgr_l10n_sv_edi_sello_recibido"></field>
            </group>
          </group>
        </page>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="invoice_cancel_wizard_view" model="ir.ui.view">
        <field name="name">Invalidacion de DTE</field>
        <field name="model">tgr_l10n_sv_edi.cancel</field>
        <field name="arch" type="xml">
            <form string="Asistente para cancelar/invalidar factura/DTE">
                <group>
                    <field name="tgr_l10n_sv_edi_tipo_invalidacion"></field>
                    <field name="tgr_l10n_sv_edi_motivo_invalidacion"></field>
                </group>
                <footer>
                    <button class="btn-primary" name="button_cancel" string="Cancelar/invalidar Factura/DTE" type="object"></button>
                    <button class="btn-default" data-hotkey="x" special="cancel" string="Cancelar"></button>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_tgr_l10n_sv_edi_cancel" model="ir.actions.act_window">
        <field name="name">Cancelar Factura</field>
        <field name="res_model">tgr_l10n_sv_edi.cancel</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="invoice_cancel_wizard_view"></field>
        <field name="target">new</field>
    </record>
</odoo>

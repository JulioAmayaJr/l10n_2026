<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"></field>
        <field name="arch" type="xml">
            <!-- TODO: => Other info? -->
            <xpath expr="//page[@name='other_info']" position="after">
                <page invisible="not move_is_dte" name="l10n_sv_edi" string="El Salvador DTE">
                    <group>
                        <group string="DTE">
                            <field invisible="1" name="move_is_dte"></field>
                            <field name="tgr_l10n_sv_edi_codigo_generacion" readonly="state != 'draft'"></field>
                            <field name="tgr_l10n_sv_edi_numero_control" readonly="1"></field>
                            <field name="tgr_l10n_sv_edi_sello_recibido" readonly="1"></field>
                            <!-- <field name="contingency_event"></field> -->
                            <!-- <field name="contingency_type"></field> -->
                            <!-- <field name="contingency_reason"></field> -->
                            <field invisible="1" name="tgr_l10n_sv_edi_json_name"></field>
                            <field filename="tgr_l10n_sv_edi_json_name" name="tgr_l10n_sv_edi_json_binary"></field>
                        </group>
                        <group string="Invalidación">
                            <field name="tgr_l10n_sv_edi_tipo_invalidacion" readonly="True"></field>
                            <field name="tgr_l10n_sv_edi_motivo_invalidacion" readonly="True"></field>
                            <field invisible="state!='cancel'" name="tgr_l10n_sv_edi_cancel_sello_recibido" readonly="1"></field>
                            <field invisible="1" name="tgr_l10n_sv_edi_cancel_json_name"></field>
                            <field filename="tgr_l10n_sv_edi_cancel_json_name" invisible="state!='cancel'" name="tgr_l10n_sv_edi_cancel_json_binary"></field>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
